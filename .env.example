# Required — create a dedicated Gmail account (e.g. yourname.tldr@gmail.com)
GMAIL_USER=your.tldr@gmail.com

# Generate at myaccount.google.com → Security → App passwords
GMAIL_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx

# Your Kindle personal document email (Manage Your Content and Devices → Preferences)
KINDLE_EMAIL=yourname@kindle.com

# Your real email for dead-letter and failure notifications
ALERT_RECIPIENT=you@example.com

# Healthchecks.io — create a free check at healthchecks.io, copy the ping URL
# Leave empty to disable
HEALTHCHECKS_URL=https://hc-ping.com/your-uuid-here

# Timezone for display in `status` command (Docker sets this automatically via Dockerfile)
# Set locally if you want timestamps in your local timezone instead of UTC
TZ=Europe/Berlin

# SMTP settings — port 587 + STARTTLS works on most VPS (Hetzner default)
# Use SMTP_SSL=true + SMTP_PORT=465 if your network blocks port 587 (some local/corporate networks)
SMTP_PORT=587
SMTP_SSL=false
